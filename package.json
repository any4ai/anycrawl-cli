{
  "name": "anycrawl-cli",
  "version": "0.2.0",
  "description": "Command-line interface for AnyCrawl. Scrape, crawl, search, and map websites from your terminal.",
  "main": "dist/index.js",
  "bin": {
    "anycrawl": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,json}\" \"skills/**/*.md\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\" \"skills/**/*.md\" \"*.{json,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "anycrawl",
    "cli",
    "web-scraping",
    "crawler",
    "scraper",
    "data-extraction",
    "llm",
    "markdown"
  ],
  "author": "AnyCrawl",
  "license": "ISC",
  "homepage": "https://docs.anycrawl.dev",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anycrawl/js-sdk": "^0.0.5",
    "@inquirer/prompts": "^8.2.1",
    "commander": "^14.0.2"
  }
}
